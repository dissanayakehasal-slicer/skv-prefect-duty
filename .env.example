# --- Vercel Postgres + API ---
# Production: omit or any value except "false" → app uses POST /api/backend.
# Local `npm run dev`: defaults to OFF (browser-only). Set true to test against `vercel dev`:
# VITE_USE_VERCEL_DB=true
VITE_USE_VERCEL_DB=
# If the API is not same-origin (rare), set the full URL to the backend handler.
# VITE_API_BASE_URL=https://your-app.vercel.app/api/backend

# Server-only (Vercel → Project → Settings → Environment Variables, not VITE_*):
# POSTGRES_URL=postgres://...   (Vercel Postgres / Neon / etc.)
# JWT_SECRET=long-random-secret-at-least-16-chars

# Local dev: run API with `npx vercel dev` (default :3000) and Vite with this file;
# optional: VITE_DEV_API_ORIGIN=http://127.0.0.1:3000
